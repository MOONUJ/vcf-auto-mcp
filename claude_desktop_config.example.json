{
  "mcpServers": {
    "vcf-auto-mcp": {
      "command": "node",
      "args": ["D:/Github/vcf-auto-mcp/dist/index.js"],
      "env": {
        "VCF_BASE_URL": "https://auto.gooddi.lab",
        "VCF_ORG": "providerconsumptionorg",
        "VCF_REFRESH_TOKEN": "YOUR_API_TOKEN_HERE",
        "TOKEN_REFRESH_BUFFER_SECONDS": "300",
        "API_TIMEOUT_MS": "30000",
        "API_MAX_RETRIES": "3",
        "LOG_LEVEL": "info"
      }
    }
  }
}
