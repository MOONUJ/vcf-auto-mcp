# ─── VCF Automation Connection ───────────────────────────────────────────────
# Base URL of the VCF Automation instance (no trailing slash)
VCF_BASE_URL=https://auto.gooddi.lab

# OAuth2 tenant/organization name used in token endpoint path
# Note: The org name in the token endpoint may be case-sensitive (e.g., ProviderConsumptionOrg)
VCF_ORG=ProviderConsumptionOrg

# ─── Authentication (choose one mode) ────────────────────────────────────────
# Mode A (preferred): Long-lived Refresh Token / API Token
# Obtain via VCF Automation UI: User Menu → My Account → API Tokens → Generate
# Leave empty to use Mode B (username/password session auth)
VCF_REFRESH_TOKEN=

# Mode B (fallback): Username + Password session authentication
# Used when VCF_REFRESH_TOKEN is empty or not set.
# Authenticates via POST /cloudapi/1.0.0/sessions (VCD cloudapi session endpoint).
# The MCP server will automatically re-authenticate when the session token nears expiry.
VCF_USERNAME=admin
VCF_PASSWORD=

# ─── Token Cache Tuning ───────────────────────────────────────────────────────
# How many seconds before actual expiry to proactively refresh the access token
# Default: 300 (5 minutes). Increase on high-latency networks.
TOKEN_REFRESH_BUFFER_SECONDS=300

# ─── HTTP Client Tuning ───────────────────────────────────────────────────────
# Maximum milliseconds to wait for any single VCF API response
# Default: 30000 (30 seconds)
API_TIMEOUT_MS=30000

# Maximum retry attempts for transient errors (5xx, network)
# Default: 3
API_MAX_RETRIES=3

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug
LOG_LEVEL=info
