                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Event"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "'Not found' if no Event with provided id"
                    }
                }
            }
        },
        "/event-broker/api/audit/filters/{filterId}": {
            "get": {
                "tags": [
                    "Audit log filter"
                ],
                "operationId": "getAuditLogFilterEntryById",
                "parameters": [
                    {
                        "name": "pageable",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "$ref": "#/components/schemas/Pageable"
                        }
                    },
                    {
                        "name": "filterId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "user_name",
                                "event_type",
                                "entity_type"
                            ]
                        }
                    },
                    {
                        "name": "search",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PageAuditLogFilterEntry"
                                }
                            }
                        }
                    }
                }
            }
        }
