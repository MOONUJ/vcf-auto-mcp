                            }
                        }
                    }
                }
            }
        },
        "/event-broker/api/events/{id}": {
            "get": {
                "tags": [
                    "Event"
                ],
                "summary": "Get Event by id",
                "description": "Retrieve the details of a specified Event.",
                "operationId": "getEvent",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "The id of an Event.",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
